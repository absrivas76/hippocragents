<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Appointment_Details</name>
        <label>Assign Appointment Details</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>FinalSummary</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>tt_FullAppointmentSummary</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <description>This flow takes an appointment number (like 1, SA-1, or SA-0001) and returns the appointment&apos;s status, subject, and description.</description>
    <environments>Default</environments>
    <formulas>
        <name>fm_IST_ScheduledStart</name>
        <dataType>String</dataType>
        <expression>TEXT(DAY(DATEVALUE({!Find_Appointment.SchedStartTime} + (5.5 / 24)))) + &quot;/&quot; + 
TEXT(MONTH(DATEVALUE({!Find_Appointment.SchedStartTime} + (5.5 / 24)))) + &quot;/&quot; + 
TEXT(YEAR(DATEVALUE({!Find_Appointment.SchedStartTime} + (5.5 / 24)))) + &quot;, &quot; + 
LPAD(TEXT(HOUR(TIMEVALUE({!Find_Appointment.SchedStartTime} + (5.5 / 24)))), 2, &quot;0&quot;) + &quot;:&quot; + 
LPAD(TEXT(MINUTE(TIMEVALUE({!Find_Appointment.SchedStartTime} + (5.5 / 24)))), 2, &quot;0&quot;) + &quot; IST&quot;</expression>
    </formulas>
    <formulas>
        <name>frmPaddedNumber</name>
        <dataType>String</dataType>
        <expression>&quot;SA-&quot; + LPAD(SUBSTITUTE({!ServiceAppointmentNumber}, &quot;SA-&quot;, &quot;&quot;), 4, &quot;0&quot;)</expression>
    </formulas>
    <interviewLabel>Get Service Appointment Details {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Get SA Details</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Find_Appointment</name>
        <label>Find Appointment</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Patient_Account</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>AppointmentNumber</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>frmPaddedNumber</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>ServiceAppointment</object>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Patient_Account</name>
        <label>Get_Patient_Account</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Assign_Appointment_Details</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Find_Appointment.AccountId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Account</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Find_Appointment</targetReference>
        </connector>
    </start>
    <status>Draft</status>
    <textTemplates>
        <name>tt_FullAppointmentSummary</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>The {!Find_Appointment.WorkType.Name} appointment for patient {!Get_Patient_Account.Name} is currently marked as {!Find_Appointment.Status} and is set for {!Find_Appointment.SchedStartTime}. You will be meeting with {!Find_Appointment.FSSK__FSK_Assigned_Service_Resource__r.Name} at {!Find_Appointment.ServiceTerritory.Name} . Is there anything else I can assist you with?</text>
    </textTemplates>
    <variables>
        <name>FinalSummary</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>ServiceAppointmentDescription</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>ServiceAppointmentNumber</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>ServiceAppointmentStatus</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
    <variables>
        <name>ServiceAppointmentSubject</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
    </variables>
</Flow>
